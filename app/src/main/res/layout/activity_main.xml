<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mirrorair_background">

    <SurfaceView
        android:id="@+id/videoSurface"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:keepScreenOn="true" />

    <LinearLayout
        android:id="@+id/overlayPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/mirrorair_background"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:id="@+id/appIconPreview"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_marginBottom="22dp"
            android:contentDescription="@string/app_name"
            android:src="@drawable/ic_launcher_foreground" />

        <TextView
            android:id="@+id/receiverNameText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/default_receiver_name"
            android:textColor="@color/mirrorair_text"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/receiverCodeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="@string/default_receiver_code"
            android:textColor="@color/mirrorair_text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="@string/default_status"
            android:textColor="@color/mirrorair_muted"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/detailText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:maxWidth="300dp"
            android:text="@string/default_detail"
            android:textColor="@color/mirrorair_muted"
            android:textSize="14sp" />

        <Button
            android:id="@+id/startButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:backgroundTint="@color/mirrorair_text"
            android:textColor="@color/mirrorair_background"
            android:text="@string/start_receiver" />

        <Button
            android:id="@+id/stopButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/mirrorair_surface"
            android:textColor="@color/mirrorair_text"
            android:text="@string/stop_receiver" />
    </LinearLayout>

</FrameLayout>
